generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// testing 
model TestConnection {
  id Int @id @default(autoincrement())
  message String
  createdAt DateTime @default(now())
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String?
  image String?
  role Role @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions Session[]
  accounts Account[]
}

enum Role {
  USER
  WRITER
  ADMIN
  SUPER_ADMIN
}

model Session {
  id String @id @default(cuid())
  userId String
  token String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String? 
  userAgent String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id String @id @default(cuid())
  userId String
  provider String
  providerAccountId String
  accessToken String?
  refreshToken String?
  AccessTokenExpiresAt DateTime?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

