{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",        // ← baguhin
    "moduleResolution": "NodeNext", // ← baguhin (hindi na "Node")
    "outDir": "./dist",
    "rootDir": "./src",          // ← ibalik sa ./src
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}